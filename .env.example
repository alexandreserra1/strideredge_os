# Copie para .env e preencha. O .env real é gitignored — NUNCA versione credenciais.

# Login com Google (opcional). Sem isso, o botão do Google fica desabilitado; login por
# e-mail/senha funciona normalmente. Crie o client em console.cloud.google.com.
GOOGLE_CLIENT_ID=

# Ambiente (development | production). Só afeta logs/observabilidade.
STRIDE_ENV=development
